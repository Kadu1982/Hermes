# Copiar para .env na VPS: cp .env.vps.example .env && nano .env
# Não commitar .env

# IP público da VPS (sem domínio)
VPS_PUBLIC_IP=72.60.55.213

# Portas no host (isoladas do stack saude)
HERMES_API_HOST_PORT=18080
HERMES_PANEL_HOST_PORT=13000

# URL da API vista pelo browser (build do painel Next.js)
NEXT_PUBLIC_HERMES_API=http://72.60.55.213:18080/api/v1

# CORS — origem do painel
HERMES_CORS_ORIGINS=http://72.60.55.213:13000

# Postgres (só rede Docker jarvis_horizon_net)
HERMES_DB_USER=hermes
HERMES_DB_PASSWORD=CHANGE_ME_long_random_db_password
HERMES_DB_NAME=hermes

# Segredos da API (gerar com: openssl rand -hex 32)
HERMES_JWT_SECRET=CHANGE_ME_jwt_secret_64_chars_min
HERMES_PAIRING_PEPPER=CHANGE_ME_pairing_pepper

# Admin inicial (bootstrap no primeiro start)
# Use um domínio válido para o validador do browser/painel (evitar .local)
HERMES_ADMIN_EMAIL=admin@example.com
HERMES_ADMIN_PASSWORD=CHANGE_ME_strong_admin_password

HERMES_MAX_UPLOAD_MB=20

# Ponte cérebro Hermes (~/.hermes) → API dispositivos (gerar: openssl rand -hex 32)
HERMES_BRAIN_SERVICE_KEY=CHANGE_ME_brain_service_key
HERMES_BRAIN_API_PUBLIC_URL=http://127.0.0.1:18080
